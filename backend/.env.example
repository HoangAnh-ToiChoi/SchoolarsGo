PORT=5000
NODE_ENV=development

# ─────────────────────────────────────────
# Supabase Local (Docker)
# ─────────────────────────────────────────
# Dùng Supabase local trong Docker — chạy `docker-compose up -d`
# URL trỏ đến Kong gateway (port 8000)
SUPABASE_URL=http://localhost:8000
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNjaG9sYXJzZ28iLCJyb2xlIjoiYW5vbiIsImlhdCI6MTY0MTc2OTIwMCwiZXhwIjoxOTU3MzQ1MjAwfQ.fake
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNjaG9sYXJzZ28iLCJyb2xlIjoic2VydmljZSIsImlhdCI6MTY0MTc2OTIwMCwiZXhwIjoxOTU3MzQ1MjAwfQ.fake

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
JWT_SECRET=scholarsgo-jwt-secret-with-at-least-32-characters-long
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────
# AI (Optional)
# ─────────────────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=

# ─────────────────────────────────────────
# Frontend URL (for CORS)
# ─────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────
# Docker Local Database (direct pg connection)
# Seed script dùng biến PG_* để kết nối trực tiếp PostgreSQL (bỏ qua Supabase gateway)
# Chạy: docker-compose up -d (khởi động postgres + pgadmin)
# ─────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=scholarsgo
PG_USER=postgres
PG_PASSWORD=scholarsgo_password
